@model ForgotPasswordViewModel
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 20px;">
                <h3 class="text-center fw-bold mb-3">KHÔI PHỤC MẬT KHẨU</h3>
                <form asp-action="ForgotPassword" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">TÊN ĐĂNG NHẬP</label>
                        <input asp-for="TenDangNhap" class="form-control" placeholder="Nhập username của bạn" />
                        <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">EMAIL ĐĂNG KÝ</label>
                        <input asp-for="Email" class="form-control" placeholder="example@gmail.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-dark w-100 fw-bold py-2">GỬI YÊU CẦU</button>
                    <div class="text-center mt-3">
                        <a asp-action="Login" class="text-decoration-none small text-muted">Quay lại Đăng nhập</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>