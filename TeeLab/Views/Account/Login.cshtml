@model Teelab.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    /* Import font Inter cho hiện đại */
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');

    body {
        background-color: #f9f9f9;
        font-family: 'Inter', sans-serif;
    }

    .login-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-box {
        background: #ffffff;
        padding: 40px;
        width: 100%;
        max-width: 450px;
        border-radius: 8px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .brand-logo {
        font-weight: 800;
        font-size: 1.8rem;
        letter-spacing: -1px;
        text-align: center;
        margin-bottom: 30px;
        text-transform: uppercase;
    }

    .login-title {
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #888;
        letter-spacing: 1px;
        text-align: center;
        margin-bottom: 30px;
    }

    /* Tùy chỉnh Input chuyên nghiệp */
    .form-label-custom {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: block;
    }

    .input-custom {
        border: 1px solid #e1e1e1;
        border-radius: 4px;
        padding: 12px 15px;
        font-size: 0.95rem;
        transition: all 0.2s ease;
    }

        .input-custom:focus {
            border-color: #000;
            box-shadow: none;
            outline: none;
        }

    /* Nút đăng nhập phong cách TeeLab */
    .btn-login-submit {
        background-color: #000;
        color: #fff;
        border: none;
        padding: 15px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        border-radius: 4px;
        margin-top: 10px;
        transition: all 0.3s ease;
    }

        .btn-login-submit:hover {
            background-color: #333;
            transform: translateY(-1px);
        }

    .login-footer-links {
        margin-top: 25px;
        text-align: center;
        font-size: 0.85rem;
    }

        .login-footer-links a {
            color: #000;
            text-decoration: none; /* Bỏ gạch chân mặc định */
            font-weight: 600;
            padding-bottom: 2px;
            margin-left: 5px;
            transition: all 0.2s ease-in-out;
        }

            .login-footer-links a:hover {
                color: #666; /* Đổi màu nhẹ khi di chuột */
                text-decoration: none; /* Đảm bảo không hiện lại gạch chân khi hover */
            }
</style>

<div class="login-wrapper">
    <div class="login-box">
        <div class="brand-logo">TEELAB</div>
        <div class="login-title">Đăng nhập tài khoản</div>
        <form asp-action="Login" asp-route-returnUrl="@Context.Request.Query["returnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.85rem;"></div>

            <div class="form-group mb-3">
                <label asp-for="TenDangNhap" class="form-label-custom">Tên đăng nhập</label>
                <input asp-for="TenDangNhap" class="form-control input-custom" placeholder="Tài khoản của bạn" />
                <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="MatKhau" class="form-label-custom">Mật khẩu</label>
                <input asp-for="MatKhau" class="form-control input-custom" type="password" placeholder="Mật khẩu của bạn" />
                <span asp-validation-for="MatKhau" class="text-danger small"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-login-submit shadow-sm">ĐĂNG NHẬP</button>
            </div>
        </form>

        <div class="login-footer-links">
            <p class="text-muted">Chưa có tài khoản? <a asp-action="Register">Đăng ký</a></p>
            <a asp-controller="Account" asp-action="ForgotPassword" class="text-muted small text-decoration-none">Quên mật khẩu?</a>
        </div>
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success small p-2 text-center">
                @TempData["Success"]
            </div>
        }
    </div>
</div>
