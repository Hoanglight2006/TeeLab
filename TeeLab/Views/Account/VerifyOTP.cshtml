@model dynamic
@{
    ViewData["Title"] = "Xác nhận OTP";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 20px;">
                <h3 class="text-center fw-bold mb-3">XÁC THỰC MÃ OTP</h3>
                <p class="text-center small text-muted">Vui lòng kiểm tra mã 6 số trong Email của bạn</p>
                
                <form asp-action="VerifyOTP" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                    <div class="mb-3">
                        <input type="text" name="otp" class="form-control text-center fw-bold"
                               placeholder="123456" maxlength="6" style="letter-spacing: 5px; font-size: 24px;" />
                    </div>
                    <button type="submit" class="btn btn-dark w-100 fw-bold py-2">XÁC NHẬN</button>
                    <div class="text-center mt-3">
                        <a asp-action="ForgotPassword" class="text-decoration-none small text-muted">Gửi lại mã khác</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>