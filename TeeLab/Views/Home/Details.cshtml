@model Teelab.Models.SanPham

@{
    ViewData["Title"] = Model.TenSP;
    var sizes = string.IsNullOrEmpty(Model.KichThuoc) ? new string[0] : Model.KichThuoc.Split(new[] { ',', ' ' }, StringSplitOptions.RemoveEmptyEntries);
    var colors = string.IsNullOrEmpty(Model.MauSac) ? new string[0] : Model.MauSac.Split(new[] { ',', ' ' }, StringSplitOptions.RemoveEmptyEntries);
}


<div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-4">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-dark">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-dark">Sản phẩm</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.TenSP</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">
            <div class="row">
                <div class="col-md-5 mb-4 mb-md-0 text-center">
                    @if (!string.IsNullOrEmpty(Model.HinhAnh))
                    {
                        <img src="~/images/sanpham/@Model.HinhAnh" class="img-fluid rounded shadow-sm w-100 border" style="object-fit: cover;" alt="@Model.TenSP" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center text-muted rounded shadow-sm w-100" style="height: 400px;">
                            Chưa có hình ảnh
                        </div>
                    }
                </div>

                <div class="col-md-7 ps-md-5">
                    <h2 class="fw-bold mb-2">@Model.TenSP</h2>
                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        <h2 class="text-danger fw-bold mb-0 me-3">@Model.SoTien.ToString("N0") VNĐ</h2>
                        @if (Model.SoLuong > 0)
                        {
                            <span class="badge bg-success px-3 py-2 fs-6">Còn hàng (@Model.SoLuong)</span>
                        }
                        else
                        {
                            <span class="badge bg-danger px-3 py-2 fs-6">Hết hàng</span>
                        }
                    </div>

                    <div class="card bg-light border-0 mb-4 shadow-sm">
                        <div class="card-body">
                            <h6 class="fw-bold mb-2">Thông tin sản phẩm:</h6>
                            <p class="text-muted mb-0" style="line-height: 1.6;">
                                @(string.IsNullOrEmpty(Model.MoTa) ? "Đang cập nhật mô tả chi tiết." : Model.MoTa)
                            </p>
                        </div>
                    </div>

                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="id" value="@Model.MaSP" />

                        <div class="row mb-4">
                            @if (sizes.Length > 0)
                            {
                                <div class="col-6">
                                    <label class="fw-bold mb-2">Kích thước</label>
                                    <select name="size" class="form-select form-select-lg shadow-sm">
                                        @foreach (var s in sizes)
                                        {
                                            <option value="@s">@s</option>
                                        }
                                    </select>
                                </div>
                            }

                            @if (colors.Length > 0)
                            {
                                <div class="col-6">
                                    <label class="fw-bold mb-2">Màu sắc</label>
                                    <select name="color" class="form-select form-select-lg shadow-sm">
                                        @foreach (var c in colors)
                                        {
                                            <option value="@c">@c</option>
                                        }
                                    </select>
                                </div>
                            }
                        </div>

                        <div class="row align-items-end">
                            <div class="col-4 col-md-3">
                                <label class="fw-bold mb-2">Số lượng</label>
                                <input type="number" name="quantity" value="1" min="1" max="@(Model.SoLuong > 0 ? Model.SoLuong : 1)" class="form-control form-control-lg text-center shadow-sm" />
                            </div>
                            <div class="col-8 col-md-9">
                                @if (Model.SoLuong == 0)
                                {
                                    <button type="button" class="btn btn-secondary btn-lg w-100 fw-bold shadow-sm" disabled>TẠM HẾT HÀNG</button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold shadow-sm">
                                        THÊM VÀO GIỎ HÀNG
                                    </button>
                                }
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


<style>
    /* 1. Tông màu và Phông chữ chủ đạo */
    :root {
        --primary-black: #111;
        --teelab-red: #d9534f;
        --bg-light: #f9f9f9;
        --border-soft: #eee;
    }

    /* 2. Làm đẹp Breadcrumb */
    .breadcrumb-item a {
        transition: color 0.2s;
        font-weight: 500;
    }

        .breadcrumb-item a:hover {
            color: var(--teelab-red) !important;
        }

    /* 3. Khung ảnh sản phẩm */
    /* col-md-5 của bạn */
    .col-md-5 img {
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
        background-color: var(--bg-light);
        border: none !important; /* Ghi đè class border của Bootstrap */
    }

    .col-md-5:hover img {
        transform: scale(1.03);
    }

    /* 4. Tiêu đề và Giá */
    h2.fw-bold {
        letter-spacing: -0.5px;
        line-height: 1.2;
        text-transform: uppercase;
        font-size: 1.75rem;
    }

    .text-danger.fw-bold {
        font-size: 1.8rem;
        letter-spacing: 1px;
        color: var(--teelab-red) !important;
    }

    /* 5. Khối thông tin sản phẩm (Card bg-light) */
    .card.bg-light {
        border-radius: 10px !important;
        border: 1px dashed #ccc !important;
        background-color: #fafafa !important;
    }

        .card.bg-light p {
            white-space: pre-line; /* Để hiển thị xuống dòng từ database */
            color: #555 !important;
        }

    /* 6. Tùy chỉnh các ô Select và Input */
    .form-select-lg, .form-control-lg {
        border: 1px solid #ddd !important;
        border-radius: 8px !important;
        font-size: 0.95rem !important;
        cursor: pointer;
        transition: all 0.2s;
    }

        .form-select-lg:focus, .form-control-lg:focus {
            border-color: var(--primary-black) !important;
            box-shadow: 0 0 0 0.2rem rgba(0,0,0,0.05) !important;
        }

    /* 7. Nút THÊM VÀO GIỎ HÀNG */
    .btn-dark {
        background-color: var(--primary-black) !important;
        border: none !important;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        letter-spacing: 1.5px;
        border-radius: 8px !important;
        transition: all 0.3s ease !important;
    }

        .btn-dark:hover {
            background-color: #333 !important;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15) !important;
        }

        .btn-dark:active {
            transform: translateY(-1px);
        }

    /* Nút tạm hết hàng */
    .btn-secondary:disabled {
        background-color: #ccc !important;
        border: none !important;
        cursor: not-allowed;
    }

    /* 8. Badge (Còn hàng/Hết hàng) */
    .badge {
        font-weight: 500;
        border-radius: 50px;
        padding: 6px 15px !important;
    }
</style>