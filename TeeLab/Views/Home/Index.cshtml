@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using Teelab.Models
@model IEnumerable<Teelab.Models.SanPham>

@{
    ViewData["Title"] = "Trang chủ Teelab";
    var sessionData = Context.Session.GetString("GioHang");
    var currentCart = sessionData == null
        ? new List<CartItem>()
        : JsonSerializer.Deserialize<List<CartItem>>(sessionData);
}

<div class="text-center py-5 mb-5 bg-light rounded shadow-sm border">
    <h1 class="display-5 fw-bold text-dark mb-3">Teelab EXCLUSIVE</h1>
    <p class="lead text-muted mb-0">Khám phá bộ sưu tập sản phẩm mới nhất</p>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        var itemInCart = currentCart.FirstOrDefault(c => c.MaSP == item.MaSP);
        var quantityInCart = itemInCart?.SoLuong ?? 0;

        <div class="col-md-3 mb-4">
            <div class="card h-100 border-0 shadow-sm" style="transition: transform 0.2s; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                
                <a asp-controller="Home" asp-action="Details" asp-route-id="@item.MaSP" class="text-decoration-none position-relative">
                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                    {
                        <img src="~/images/sanpham/@item.HinhAnh" class="card-img-top rounded-top" style="height: 280px; object-fit: cover;" alt="@item.TenSP" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center text-muted rounded-top" style="height: 280px;">
                            No Image
                        </div>
                    }
                    
                    @* Badge hiển thị góc trái ảnh *@
                    @if (item.SoLuong == 0)
                    {
                        <span class="badge bg-danger position-absolute top-0 start-0 m-2 px-2 py-1 shadow-sm">Hết hàng</span>
                    }
                </a>

                <div class="card-body d-flex flex-column">
                    <a asp-controller="Home" asp-action="Details" asp-route-id="@item.MaSP" class="text-decoration-none text-dark">
                        <h5 class="card-title text-truncate fw-bold mb-1">@item.TenSP</h5>
                    </a>

                    <div class="text-danger fw-bold fs-5 mb-3">@item.SoTien.ToString("N0") đ</div>
                    
                    <div class="mt-auto">
                        <p class="text-muted small mb-1">
                            Size: @(string.IsNullOrEmpty(item.KichThuoc) ? "Free size" : item.KichThuoc)
                        </p>
                        
                        @if (item.SoLuong > 0)
                        {
                            <p class="text-success small fw-bold mb-2">Còn @item.SoLuong cái</p>
                        }

                        @if (quantityInCart > 0)
                        {
                            <div class="mb-2">
                                <span class="badge bg-info text-dark w-100 text-start px-2 py-1">
                                    Đang có @quantityInCart cái trong giỏ
                                </span>
                            </div>
                        }
                    </div>
                </div>

                <div class="card-footer bg-white border-0 pt-0 pb-3">
                    @if (item.SoLuong == 0)
                    {
                        <button class="btn btn-secondary w-100 fw-bold" disabled>HẾT HÀNG</button>
                    }
                    else
                    {
                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex gap-2">
                            <input type="hidden" name="id" value="@item.MaSP" />
                            <input type="number" name="quantity" value="1" min="1" max="@item.SoLuong" class="form-control text-center px-1" style="width: 60px;" />
                            <button type="submit" class="btn btn-dark flex-grow-1 fw-bold">
                                @(quantityInCart > 0 ? "THÊM TIẾP" : "MUA NGAY")
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>