@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using Teelab.Models
@model IEnumerable<Teelab.Models.SanPham>

<style>
    .banner-exclusive-v2 {
        position: relative;
        width: 100%;
        max-height: 450px; 
        margin: 20px 0 40px 0;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .banner-main-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .banner-overlay-content {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        background: rgba(0, 0, 0, 0.15); /* Giảm độ tối để ảnh mẫu rõ hơn */
        z-index: 2;
        /* Quan trọng: Cho phép các phần tử con nhận sự kiện chuột */
        pointer-events: none; 
    }

    .title-container {
        /* Cho phép container này nhận chuột để hover */
        pointer-events: auto; 
        padding: 10px 20px;
    }

    .teelab-title {
        color: #ffffff !important;
        font-size: clamp(2.5rem, 7vw, 4.5rem);
        font-weight: 950; /* Cực đậm */
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 12px; /* Khoảng cách chữ rộng ra cho sang */
        text-shadow: 0 5px 15px rgba(0,0,0,0.3);
        
        /* Hiệu ứng mượt */
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        display: inline-block;
    }

    /* Hiệu ứng Hover mới: To ra và sáng rực lên */
    .teelab-title:hover {
        transform: scale(1.1) translateY(-5px); /* To ra và nhích lên trên tí */
        letter-spacing: 15px; /* Giãn chữ thêm khi hover */
        text-shadow: 0 10px 25px rgba(255,255,255,0.3), 0 0 50px rgba(255,255,255,0.2);
        color: #f8f9fa !important;
    }

    .banner-subtitle {
        pointer-events: auto;
        color: rgba(255, 255, 255, 0.9) !important;
        font-size: 1.1rem;
        font-weight: 300;
        margin-top: 15px;
        letter-spacing: 3px;
        text-transform: lowercase;
        font-style: italic;
    }

    /* Đảm bảo thoát lỗi Razor */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@media (max-width: 768px) {
        .banner-exclusive { height: 350px; }
        .banner-text-overlay h1 { font-size: 2.5rem; letter-spacing: 3px; }
        .banner-text-overlay p { font-size: 0.9rem; }
    }
</style>
@{
    ViewData["Title"] = "Trang chủ Teelab";
    var sessionData = Context.Session.GetString("GioHang");
    var currentCart = sessionData == null
        ? new List<CartItem>()
        : JsonSerializer.Deserialize<List<CartItem>>(sessionData);
}

<div class="banner-exclusive-v2">
    <img src="~/images/avatars/slider_1.jpg" alt="Banner Teelab" class="banner-main-img" />

    <div class="banner-overlay-content">
        <div class="title-container">
            <h1 class="teelab-title">TEELAB</h1>
        </div>
        <p class="banner-subtitle">Khám phá bộ sưu tập sản phẩm mới nhất</p>
    </div>
</div>
<div class="d-flex justify-content-center flex-wrap gap-2 mb-4">
    <a asp-action="Index" asp-route-category="" asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-priceRange="@ViewData["CurrentPrice"]"
       class="btn @(string.IsNullOrEmpty((string)ViewData["CurrentCategory"]) ? "btn-dark" : "btn-outline-dark") rounded-pill px-4 fw-bold">Tất cả</a>
    
    <a asp-action="Index" asp-route-category="AT" asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-priceRange="@ViewData["CurrentPrice"]"
       class="btn @((string)ViewData["CurrentCategory"] == "AT" ? "btn-dark" : "btn-outline-dark") rounded-pill px-4 fw-bold">Áo Thun</a>
       
    <a asp-action="Index" asp-route-category="HD" asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-priceRange="@ViewData["CurrentPrice"]"
       class="btn @((string)ViewData["CurrentCategory"] == "HD" ? "btn-dark" : "btn-outline-dark") rounded-pill px-4 fw-bold">Áo Hoodie</a>

    <a asp-action="Index" asp-route-category="Q" asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-priceRange="@ViewData["CurrentPrice"]"
       class="btn @((string)ViewData["CurrentCategory"] == "Q" ? "btn-dark" : "btn-outline-dark") rounded-pill px-4 fw-bold">Quần</a>
       
    <a asp-action="Index" asp-route-category="PK" asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-priceRange="@ViewData["CurrentPrice"]"
       class="btn @((string)ViewData["CurrentCategory"] == "PK" ? "btn-dark" : "btn-outline-dark") rounded-pill px-4 fw-bold">Phụ kiện</a>
</div>

<div class="row mb-5 justify-content-center">
    <div class="col-md-8">
        <form asp-controller="Home" asp-action="Index" method="get" class="d-flex shadow-sm rounded">
            <input type="hidden" name="category" value="@ViewData["CurrentCategory"]" />
            
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                   class="form-control form-control-lg border-dark rounded-start"
                   placeholder="Nhập tên áo bạn muốn tìm..." style="border-right: none;" />
                   
            <select name="priceRange" class="form-select border-dark border-start-0" style="max-width: 220px; border-radius: 0;">
                <option value="">-- Mọi mức giá --</option>
                <option value="duoi300" selected="@((string)ViewData["CurrentPrice"] == "duoi300")">Dưới 300.000đ</option>
                <option value="300den500" selected="@((string)ViewData["CurrentPrice"] == "300den500")">300.000đ - 500.000đ</option>
                <option value="tren500" selected="@((string)ViewData["CurrentPrice"] == "tren500")">Trên 500.000đ</option>
            </select>
            
            <button type="submit" class="btn btn-dark btn-lg rounded-end px-4"><i class="bi bi-search"></i> Lọc</button>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <h4 class="text-muted"><i class="bi bi-emoji-frown fs-1 d-block mb-3"></i>Không tìm thấy sản phẩm nào phù hợp với yêu cầu của bạn.</h4>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark mt-3">Xóa bộ lọc & Xem tất cả</a>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            var itemInCart = currentCart.FirstOrDefault(c => c.MaSP == item.MaSP);
            var quantityInCart = itemInCart?.SoLuong ?? 0;

            <div class="col-md-3 mb-4">
                <div class="card h-100 border-0 shadow-sm" style="transition: transform 0.2s; cursor: pointer;"
                     onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                    
                    <a asp-controller="Home" asp-action="Details" asp-route-id="@item.MaSP" class="text-decoration-none position-relative">
                        @if (!string.IsNullOrEmpty(item.HinhAnh))
                        {
                            <img src="~/images/sanpham/@item.HinhAnh" class="card-img-top rounded-top" style="height: 280px; object-fit: cover;" alt="@item.TenSP" />
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center text-muted rounded-top" style="height: 280px;">
                                No Image
                            </div>
                        }
                        
                        @if (item.SoLuong == 0)
                        {
                            <span class="badge bg-danger position-absolute top-0 start-0 m-2 px-2 py-1 shadow-sm">Hết hàng</span>
                        }
                    </a>

                    <div class="card-body d-flex flex-column">
                        <a asp-controller="Home" asp-action="Details" asp-route-id="@item.MaSP" class="text-decoration-none text-dark">
                            <h5 class="card-title text-truncate fw-bold mb-1">@item.TenSP</h5>
                        </a>

                        <div class="text-danger fw-bold fs-5 mb-3">@item.SoTien.ToString("N0") đ</div>
                        
                        <div class="mt-auto">
                            <p class="text-muted small mb-1">
                                Size: @(string.IsNullOrEmpty(item.KichThuoc) ? "Free size" : item.KichThuoc)
                            </p>
                            
                            @if (item.SoLuong > 0)
                            {
                                <p class="text-success small fw-bold mb-2">Còn @item.SoLuong cái</p>
                            }

                            @if (quantityInCart > 0)
                            {
                                <div class="mb-2">
                                    <span class="badge bg-info text-dark w-100 text-start px-2 py-1">
                                        Đang có @quantityInCart cái trong giỏ
                                    </span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card-footer bg-white border-0 pt-0 pb-3">
                        @if (item.SoLuong == 0)
                        {
                            <button class="btn btn-secondary w-100 fw-bold" disabled>HẾT HÀNG</button>
                        }
                        else
                        {
                            @if (User.IsInRole("QuanLy") || User.IsInRole("NhanVien"))
                            {
                                <button class="btn btn-outline-secondary w-100 fw-bold" disabled title="Chỉ dành cho khách hàng">CHỈ KHÁCH HÀNG MUA</button>
                            }
                            else
                            {
                                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex gap-2">
                                    <input type="hidden" name="id" value="@item.MaSP" />
                                    <input type="number" name="quantity" value="1" min="1" max="@item.SoLuong" class="form-control text-center px-1" style="width: 60px;" />
                                    <button type="submit" class="btn btn-dark flex-grow-1 fw-bold">
                                        @(quantityInCart > 0 ? "THÊM TIẾP" : "MUA NGAY")
                                    </button>
                                </form>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}