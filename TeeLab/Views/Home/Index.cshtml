@model IEnumerable<Teelab.Models.SanPham>

@{
    ViewData["Title"] = "Trang chủ Teelab";
}

<div class="text-center">
    <h1 class="display-4">Chào mừng đến với TEELAB</h1>
    <p>Bộ sưu tập sản phẩm mới nhất</p>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@item.TenSP</h5>
                    <p class="card-text text-danger fw-bold">@item.SoTien.ToString("N0") VNĐ</p>
                    <p class="text-muted small">
                        Tình trạng:
                        @if (item.SoLuong > 0)
                        {
                            <span class="text-success">Còn @item.SoLuong sản phẩm</span>
                        }
                        else
                        {
                            <span class="text-danger">Hết hàng</span>
                        }
                    </p>
                </div>
                <div class="card-footer bg-white border-top-0 text-center">
                    @if (item.TinhTrang == "Hết hàng")
                    {
                        <button class="btn btn-secondary w-100" disabled>Hết hàng</button>
                    }
                    else
                    {
                        <div class="card-footer bg-white border-top-0">
                            @if (item.SoLuong == 0)
                            {
                                <button class="btn btn-secondary w-100" disabled>Hết hàng</button>
                            }
                            else
                            {
                                @* Biến nút bấm thành Form để gửi số lượng *@
                                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                    <input type="hidden" name="id" value="@item.MaSP" />
                                    <div class="input-group mb-2">
                                        <span class="input-group-text">SL</span>
                                        @* Ô nhập số lượng, tối đa là số lượng trong kho *@
                                        <input type="number" name="quantity" value="1" min="1" max="@item.SoLuong" class="form-control" />
                                    </div>
                                    <button type="submit" class="btn btn-dark w-100">Thêm vào giỏ</button>
                                </form>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>