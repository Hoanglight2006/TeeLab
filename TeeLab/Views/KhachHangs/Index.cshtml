@model IEnumerable<Teelab.Models.ThanhToan>

@{
    ViewData["Title"] = "Trang cá nhân - Lịch sử đơn hàng";
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.9);
        --primary-gradient: linear-gradient(135deg, #0d6efd 0%, #003da5 100%);
    }

    body {
        background-color: #f8f9fa; /* Màu nền xám cực nhẹ cho nổi bật Card */
    }

    /* Tùy chỉnh Sidebar */
    .profile-card {
        border-radius: 1rem;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .user-avatar-wrapper {
        position: relative;
        display: inline-block;
    }

    .user-avatar-icon {
        width: 80px;
        height: 80px;
        background: var(--primary-gradient);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(13, 110, 253, 0.3);
    }

    .sidebar-link {
        border: none !important;
        margin: 5px 15px;
        border-radius: 0.8rem !important;
        transition: all 0.2s ease;
    }

        .sidebar-link.active {
            background: var(--primary-gradient) !important;
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
        }

        .sidebar-link:hover:not(.active) {
            background-color: #f1f4f9 !important;
            transform: translateX(5px);
        }

    /* Tùy chỉnh Bảng Đơn Hàng */
    .order-card {
        border-radius: 1rem;
        border: none;
    }

    .table thead th {
        background-color: #fcfcfd;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        font-weight: 700;
        border-bottom-width: 1px;
    }

    .table tbody tr {
        transition: background-color 0.2s ease;
    }

        .table tbody tr:hover {
            background-color: #f8faff !important;
        }

    /* Badge trạng thái kiểu hiện đại */
    .status-pill {
        padding: 0.5em 1em !important;
        font-weight: 600;
        border-radius: 2rem !important;
        font-size: 0.75rem;
    }

    /* Hiệu ứng nút Hủy đơn */
    .btn-cancel {
        border-radius: 0.5rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            background-color: #dc3545;
            color: white;
            box-shadow: 0 4px 10px rgba(220, 53, 69, 0.2);
        }

    /* Mã đơn hàng nổi bật */
    .order-id {
        font-family: 'Monaco', 'Consolas', monospace;
        letter-spacing: -0.5px;
        text-decoration: none;
    }
</style>
<div class="container mt-5 mb-5">
    @if (TempData["CheckoutSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill fs-4 me-3"></i>
                <div>
                    <strong class="d-block">Thành công!</strong>
                    @TempData["CheckoutSuccess"]
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm border-0 profile-card">
                <div class="card-body text-center py-5">
                    <div class="user-avatar-wrapper mb-3">
                        <div class="user-avatar-icon">
                            <i class="bi bi-person-fill fs-1"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-1">@User.Identity.Name</h5>
                    <span class="badge bg-light text-dark border shadow-sm px-3 py-2 rounded-pill small">
                        <i class="bi bi-patch-check-fill text-primary me-1"></i> Khách hàng thành viên
                    </span>
                </div>
                <div class="list-group list-group-flush pb-3">
                    <a href="#" class="list-group-item list-group-item-action active sidebar-link py-3">
                        <i class="bi bi-bag-check-fill me-2"></i> Đơn hàng của tôi
                    </a>
                    <a href="#" class="list-group-item list-group-item-action sidebar-link py-3 text-muted">
                        <i class="bi bi-person-gear me-2"></i> Cài đặt tài khoản
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold mb-0 text-dark">Lịch sử Đơn hàng</h3>
                <span class="text-muted small">Tổng cộng: <strong>@Model.Count()</strong> đơn hàng</span>
            </div>

            @if (!Model.Any())
            {
                <div class="card border-0 shadow-sm text-center py-5 rounded-4">
                    <div class="card-body py-5">
                        <div class="bg-light d-inline-flex p-4 rounded-circle mb-4">
                            <i class="bi bi-box2 text-muted" style="font-size: 3rem;"></i>
                        </div>
                        <h4 class="fw-bold text-dark">Chưa có đơn hàng nào</h4>
                        <p class="text-muted mb-4">Hãy lấp đầy giỏ hàng của bạn bằng những sản phẩm tuyệt vời từ TeeLab.</p>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-dark btn-lg px-5 rounded-pill shadow-sm">Mua sắm ngay</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm order-card">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4 py-3">Mã Đơn</th>
                                        <th class="py-3 text-center">Ngày đặt</th>
                                        <th class="py-3 text-end">Tổng tiền</th>
                                        <th class="py-3 text-center">Trạng thái</th>
                                        <th class="py-3 text-center pe-4">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var donHang in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 py-4">
                                                <span class="order-id fw-bold text-primary">#@donHang.MaTT</span>
                                            </td>
                                            <td class="py-4 text-center text-muted small">
                                                @donHang.NgayTao.ToString("dd/MM/yyyy")<br />
                                                <span class="text-opacity-50">@donHang.NgayTao.ToString("HH:mm")</span>
                                            </td>
                                            <td class="py-4 text-end fw-bold text-dark fs-6">
                                                @donHang.TongTien.ToString("N0") <span class="small fw-normal">đ</span>
                                            </td>
                                            <td class="py-4 text-center">
                                                @{
                                                    var badgeClass = donHang.TrangThai switch
                                                    {
                                                        "Chờ xác nhận" => "bg-warning text-dark bg-opacity-25 border-warning",
                                                        "Đang giao" => "bg-info text-dark bg-opacity-25 border-info",
                                                        "Giao hàng thành công" => "bg-success text-white",
                                                        "Đã hủy" => "bg-secondary text-white bg-opacity-50",
                                                        _ => "bg-secondary text-white"
                                                    };
                                                }
                                                <span class="badge status-pill border @badgeClass">@donHang.TrangThai</span>
                                            </td>
                    
                                            <td class="py-4 text-center pe-4">
                                                @* Nút Chi tiết luôn hiển thị *@
                                                <a asp-controller="KhachHangs" asp-action="OrderDetail" asp-route-id="@donHang.MaTT" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm mb-2 d-inline-block">
                                                    <i class="bi bi-eye me-1"></i>Chi tiết
                                                </a>
                                                <br />

                                                @if (donHang.TrangThai == "Chờ xác nhận")
                                                {
                                                    <form asp-controller="KhachHangs" asp-action="HuyDon" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không?');">
                                                        <input type="hidden" name="maTT" value="@donHang.MaTT" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-cancel px-3 shadow-sm">
                                                            <i class="bi bi-trash3 me-1"></i>Hủy đơn
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-light disabled text-muted rounded-pill px-3 border-0">
                                                        <i class="bi bi-lock me-1"></i>Đã khóa
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
