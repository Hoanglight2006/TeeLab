@model Teelab.Models.ThanhToan

<div class="container py-5">
    <h3>Chi tiết đơn hàng: @Model.MaTT</h3>
    <a href="javascript:history.back()" class="btn-back">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <h5>Thông tin khách hàng</h5>
            <p><strong>Họ tên:</strong> @(Model.KhachHang?.Hoten ?? "Chưa cập nhật")</p>
            <p><strong>Số điện thoại:</strong> @(Model.KhachHang?.Sdt ?? "Chưa cập nhật")</p>
            <p><strong>Địa chỉ giao hàng:</strong> @(Model.KhachHang?.Diachi ?? "Chưa cập nhật")</p>
        </div>
        <div class="col-md-6">
            <h5>Thông tin đơn hàng</h5>
            <p><strong>Ngày đặt:</strong> @Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</p>
            <p><strong>Trạng thái:</strong> <span class="badge bg-warning text-dark">@Model.TrangThai</span></p>
            <p><strong>Ghi chú:</strong> @(string.IsNullOrEmpty(Model.GhiChu) ? "Không có ghi chú" : Model.GhiChu)</p>
        </div>
    </div>
    <table class="table mt-4">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.ChiTietThanhToans)
            {
                <tr>
                    <td>@item.SanPham?.TenSP (@item.MauSac / @item.KichThuoc)</td>
                    <td>@item.SoLuong</td>
                    <td>@item.Gia.ToString("N0")đ</td>
                    <td>@((item.SoLuong * item.Gia).ToString("N0"))đ</td>
                </tr>
            }
        </tbody>
    </table>
    <h4 class="text-end">Tổng cộng: @Model.TongTien.ToString("N0")đ</h4>
</div>
<style>
    /* Tổng thể container */
    .container.py-5 {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.05);
        padding: 40px !important;
        margin-top: 30px;
        border: 1px solid #eee;
    }

    /* Tiêu đề chính */
    h3 {
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #1a1a1a;
        margin-bottom: 25px;
    }

    /* Tiêu đề con (Thông tin khách hàng/đơn hàng) */
    h5 {
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #6c757d; /* Màu xám dịu mắt */
        margin-bottom: 15px;
        border-bottom: 2px solid #eee;
        padding-bottom: 8px;
    }

    /* Nội dung text thông tin */
    p {
        font-size: 0.95rem;
        margin-bottom: 8px;
        color: #333;
    }

    /* Bảng sản phẩm */
    .table.mt-4 {
        margin-top: 40px !important;
        border-collapse: separate;
        border-spacing: 0;
    }

    .table thead th {
        background: #f8f9fa;
        color: #1a1a1a;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        padding: 15px;
        border-top: none;
        border-bottom: 2px solid #1a1a1a;
    }

    .table tbody td {
        padding: 15px;
        vertical-align: middle;
        border-bottom: 1px solid #eee;
    }

        /* FIX LỖI HIỂN THỊ SỐ LƯỢNG: Thêm chữ 'x' bằng CSS để không phải sửa code */
        .table tbody td:nth-child(2)::before {
            content: "x";
            font-weight: 600;
            margin-right: 2px;
        }

    /* Dòng tổng cộng (Hà bảo không cần sửa nút, mình chỉ căn chỉnh lề và màu sắc dịu) */
    .text-end {
        margin-top: 30px;
        padding: 20px;
        background: #f8f9fa; /* Nền xám nhạt dịu mắt */
        border-radius: 8px;
        display: block;
    }

    h4.text-end {
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 0;
    }

    /* Badge trạng thái */
    .badge.bg-warning {
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
    }
</style>   