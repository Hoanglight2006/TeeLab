@model IEnumerable<TeeLab.Models.NhanVien>

@{
    ViewData["Title"] = "Quản lý Nhân sự";
}

<div class="container-fluid mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0"><i class="bi bi-people-fill text-primary me-2"></i>Quản lý Nhân viên</h2>
        <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm"><i class="bi bi-plus-lg me-1"></i> Thêm Nhân viên mới</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">ID</th>
                            <th class="py-3">Họ và tên</th>
                            <th class="py-3">Số điện thoại</th>
                            <th class="py-3">Tài khoản (Đăng nhập)</th>
                            <th class="pe-4 py-3 text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3 fw-bold">#@item.Id</td>
                                <td class="py-3 fw-bold text-dark">@item.Hoten</td>
                                <td class="py-3">@item.Sdt</td>
                                <td class="py-3"><span class="badge bg-info text-dark px-2 py-1 fs-6">@item.TenDangNhap</span></td>
                                <td class="pe-4 py-3 text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary px-3 rounded-pill">Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger px-3 rounded-pill ms-1">Xóa</a>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">Hệ thống chưa có nhân viên nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>