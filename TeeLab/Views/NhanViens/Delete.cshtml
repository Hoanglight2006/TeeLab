@model TeeLab.Models.NhanVien

@{
    ViewData["Title"] = "Xóa Nhân viên";
}

<div class="container-fluid mt-4 mb-5">
    <h2 class="fw-bold mb-4 text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Xóa Tài khoản Nhân viên</h2>

    <div class="alert alert-warning shadow-sm border-0" role="alert">
        <h5 class="alert-heading fw-bold">Cảnh báo nghiêm trọng!</h5>
        <p class="mb-0">Bạn đang chuẩn bị xóa tài khoản Nhân viên <strong>@Model.Hoten</strong> (Tài khoản: @Model.TenDangNhap). Hành động này không thể hoàn tác và sẽ thu hồi mọi quyền truy cập của người này.</p>
    </div>

    <div class="card shadow-sm border-0 mt-4">
        <div class="card-body p-4 p-md-5">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th style="width: 150px;" class="text-muted">Mã Nhân viên:</th>
                                <td class="fw-bold fs-5">#@Model.Id</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Họ và tên:</th>
                                <td class="fw-bold text-dark fs-5">@Model.Hoten</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Số điện thoại:</th>
                                <td>@Model.Sdt</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Địa chỉ:</th>
                                <td>@Model.Diachi</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Tên đăng nhập:</th>
                                <td><span class="badge bg-info text-dark fs-6 px-3 py-2">@Model.TenDangNhap</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <hr class="mt-4 mb-4" />
            
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-5 py-2 fw-bold me-2 shadow-sm">XÁC NHẬN XÓA</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-5 py-2 fw-bold">Hủy bỏ</a>
            </form>
        </div>
    </div>
</div>