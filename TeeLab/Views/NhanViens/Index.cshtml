@model IEnumerable<Teelab.Models.ThanhToan>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    var donChuaXuLy = Model.Where(m => m.TrangThai == "Chờ xác nhận" || m.TrangThai == "Đang giao" || m.TrangThai == "Thanh toán thất bại").ToList();
    var donThanhCong = Model.Where(m => m.TrangThai == "Giao hàng thành công").ToList();
    var donDaHuy = Model.Where(m => m.TrangThai == "Đã hủy").ToList();
}

<style>
    :root {
        --teelab-dark: #1a1a1a;
        --teelab-blue: #007bff;
        --teelab-success: #28a745;
        --teelab-danger: #dc3545;
        --bg-light: #f8f9fa;
    }

    body { background-color: #f4f7f6; color: #333; }

    /* Tiêu đề phần */
    .section-header {
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 2rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
    }

    .section-header i { margin-right: 10px; font-size: 1.2rem; }

    /* Card & Table Custom */
    .custom-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        background: white;
    }

    .table thead th {
        background-color: #fafafa;
        color: var(--teelab-dark);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        border-bottom: 2px solid #eee;
        padding: 1.2rem 1rem;
    }

    .table tbody td {
        padding: 1.2rem 1rem;
        border-bottom: 1px solid #f8f9fa;
        vertical-align: middle;
    }

    /* Hiệu ứng hover cho hàng */
    .table-hover tbody tr:hover {
        background-color: #fcfcfc;
    }

    /* Badge & Status Pill */
    .status-pill {
    padding: 6px 16px; /* Tăng padding trái phải cho nút rộng ra */
    border-radius: 30px;
    font-weight: 600;
    font-size: 0.75rem;
    display: inline-block;
    white-space: nowrap; /* QUAN TRỌNG: Giúp chữ không bao giờ bị nhảy xuống dòng */
    min-width: 110px;    /* Đảm bảo các nút có độ rộng tối thiểu bằng nhau cho đẹp */
    text-align: center;  /* Căn chữ ra giữa nút */
}

    .pill-warning { background: #fff3cd; color: #856404; }
    .pill-info { background: #d1ecf1; color: #0c5460; }
    .pill-success { background: #d4edda; color: #155724; }
    .pill-danger { background: #f8d7da; color: #721c24; }
    .pill-secondary { background: #e2e3e5; color: #383d41; }
    /* Màu riêng cho VNPay */
    .pill-vnpay { background: #e7f1ff; color: #0056b3; border: 1px solid #b8daff; }

    /* Dropdown & Button */
    .status-select {
        border-radius: 8px;
        border: 1px solid #ddd;
        padding: 5px 10px;
        font-size: 0.85rem;
        transition: all 0.3s;
    }
    /* Nút Lưu - Sửa lỗi màu chữ và hiệu ứng hover */
    .btn-save-status {
        background: #007bff !important; /* Xanh Primary */
        color: #ffffff !important;      /* Chữ trắng tuyệt đối */
        border: none;
        border-radius: 8px;
        padding: 6px 18px;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.2s ease-in-out;
        box-shadow: 0 2px 5px rgba(0,123,255,0.3);
        display: inline-block;
    }



    /* Nút Chi tiết đơn hàng (Màu xanh nhạt dịu mắt) */
    .btn-view-detail {
        color: #007bff !important;
        background: #e7f1ff !important;
        border: 1px solid #b8daff !important;
        border-radius: 8px;
        padding: 5px 12px;
        transition: 0.2s;
    }


 
    /* Text Helpers */
    .product-list li {
        margin-bottom: 4px;
        font-size: 0.9rem;
    }
    
    .text-price { font-weight: 700; color: var(--teelab-danger); }
</style>

<div class="container-fluid px-4 py-4">
@* --- ĐƠN HÀNG ĐANG XỬ LÝ --- *@
    <div class="section-header text-primary">
        <i class="bi bi-lightning-charge-fill"></i> ĐƠN HÀNG ĐANG XỬ LÝ (@donChuaXuLy.Count)
    </div>

    <div class="card custom-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Ngày đặt</th>
                        <th>Khách hàng</th>
                        <th style="width: 20%;">Sản phẩm (SL)</th>
                        <th class="text-center">Size/Màu</th>
                        <th>Tổng tiền</th>
                        <th>Phương thức</th> @* BỔ SUNG *@
                        <th>Trạng thái</th>
                        <th class="text-center pe-4">Thao tác nhanh</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in donChuaXuLy)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.NgayTao.ToString("dd/MM")</div>
                                <div class="text-muted small">@item.NgayTao.ToString("HH:mm")</div>
                            </td>
                            <td>
                                <a aasp-controller="KhachHangs" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none fw-bold text-dark">
                                    @(item.KhachHang?.Hoten ?? "Khách ẩn danh")
                                    <i class="bi bi-arrow-up-right-circle ms-1 text-muted"></i>
                                </a>
                            </td>
                            <td>
                                <ul class="list-unstyled mb-0 product-list">
                                    @foreach (var ct in item.ChiTietThanhToans)
                                    {
                                        <li class="text-truncate">
                                            <span class="badge bg-light text-dark border me-1">@ct.SoLuong</span> 
                                            @ct.SanPham?.TenSP
                                        </li>
                                    }
                                </ul>
                            </td>
                            <td class="text-center">
                                @foreach (var ct in item.ChiTietThanhToans) {
                                    <span class="badge bg-white border text-dark mb-1">@ct.KichThuoc / @ct.MauSac</span><br/>
                                }
                            </td>
                            <td class="text-price">@item.TongTien.ToString("N0")đ</td>
                            <td> @* HIỂN THỊ PHƯƠNG THỨC *@
                                @if (item.PhuongThucTT != null && item.PhuongThucTT.Contains("VNPay"))
                                {
                                    <span class="status-pill pill-vnpay"><i class="bi bi-credit-card-2-back-fill me-1"></i>VNPay</span>
                                }
                                else
                                {
                                    <span class="status-pill pill-secondary"><i class="bi bi-cash me-1"></i>COD</span>
                                }
                            </td>
                            <td>
                                <span class="status-pill @(item.TrangThai == "Chờ xác nhận" ? "pill-warning" : item.TrangThai == "Thanh toán thất bại" ? "pill-danger" : "pill-info")">
                                    @item.TrangThai
                                </span>
                            </td>
                            <td class="pe-4 text-center">
                               <div class="d-flex justify-content-center align-items-center">
        <a asp-controller="KhachHangs" asp-action="OrderDetail" asp-route-id="@item.MaTT" 
           class="btn btn-view-detail me-2" title="Xem chi tiết đơn">
            <i class="bi bi-eye-fill"></i>
        </a>

        <form asp-controller="NhanViens" asp-action="CapNhatTrangThai" method="post" class="d-flex" onsubmit="return xacNhanCapNhat(event, this);">
            <input type="hidden" name="maTT" value="@item.MaTT" />
            <select name="trangThaiMoi" class="form-select-sm status-select me-2 shadow-sm">
                <option value="Chờ xác nhận" selected="@(item.TrangThai == "Chờ xác nhận")">Chờ xác nhận</option>
                <option value="Đang giao" selected="@(item.TrangThai == "Đang giao")">Đang giao</option>
                <option value="Giao hàng thành công">Thành công</option>
                <option value="Đã hủy">Hủy đơn</option>
            </select>
            <button type="submit" class="btn btn-save-status">Lưu</button>
        </form>
    </div>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* --- ĐƠN HÀNG THÀNH CÔNG --- *@
    <div class="section-header text-success">
        <i class="bi bi-check-all"></i> ĐƠN HÀNG HOÀN TẤT (@donThanhCong.Count)
    </div>
    <div class="card custom-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Ngày đặt</th>
                        <th>Khách hàng</th>
                        <th>Tổng tiền</th>
                        <th>Phương thức</th> @* BỔ SUNG *@
                        <th class="text-center">Chi tiết </th>
                        <th class="pe-4 text-end">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in donThanhCong)
                    {
                        <tr>
                            <td class="ps-4">@item.NgayTao.ToString("dd/MM/yyyy")</td>
                            <td class="fw-bold">@item.KhachHang?.Hoten</td>
                            <td class="text-price">@item.TongTien.ToString("N0")đ</td>
                            <td>@item.PhuongThucTT</td> @* HIỂN THỊ PHƯƠNG THỨC *@
                            <td class="text-center">
                                <a asp-controller="KhachHangs" asp-action="OrderDetail" asp-route-id="@item.MaTT" 
                                class="text-decoration-none" title="Xem chi tiết đơn hàng">
                                <span class="badge rounded-pill bg-light text-primary border border-primary px-3 py-2">
                                <i class="bi bi-box-seam me-1"></i> 
                                @item.ChiTietThanhToans.Count() sản phẩm
                                </span>
                                </a>
                            </td>
                            <td class="pe-4 text-end">
                                <span class="status-pill pill-success"><i class="bi bi-patch-check-fill me-1"></i>Đã chốt</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* --- ĐƠN HÀNG ĐÃ HỦY --- *@
    <div class="section-header text-danger">
        <i class="bi bi-trash3"></i> ĐƠN HÀNG ĐÃ HỦY (@donDaHuy.Count)
    </div>
    <div class="card custom-card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <tbody>
                    @foreach (var item in donDaHuy)
                    {
                        <tr class="opacity-75">
                            <td class="ps-4 py-3" style="width: 150px;">@item.NgayTao.ToString("dd/MM/yyyy")</td>
                            <td class="fw-bold text-muted">@item.KhachHang?.Hoten</td>
                            <td class="text-decoration-line-through">@item.TongTien.ToString("N0")đ</td>
                            <td class="text-muted" style="width: 120px;">@item.PhuongThucTT</td> @* BỔ SUNG *@
                            <td class="pe-4 text-end">
                                <span class="status-pill pill-danger">Đã hủy đơn</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function xacNhanCapNhat(e, form) {
            e.preventDefault();
            var select = form.querySelector('select[name="trangThaiMoi"]');
            var trangThaiMoi = select.options[select.selectedIndex].text;

            Swal.fire({
                title: 'Cập nhật đơn hàng?',
                text: "Bạn có chắc muốn chuyển sang: " + trangThaiMoi + "?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#1a1a1a',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Xác nhận',
                cancelButtonText: 'Quay lại',
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            })
        }
    </script>
}