@model IEnumerable<Teelab.Models.ThanhToan>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    
    // LỌC DỮ LIỆU RA 3 BẢNG
    var donChuaXuLy = Model.Where(m => m.TrangThai == "Chờ xác nhận" || m.TrangThai == "Đang giao").ToList();
    var donThanhCong = Model.Where(m => m.TrangThai == "Giao hàng thành công").ToList();
    var donDaHuy = Model.Where(m => m.TrangThai == "Đã hủy").ToList();
}

<div class="container-fluid mt-4 mb-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <h3 class="fw-bold mb-3 text-primary"><i class="bi bi-hourglass-split me-2"></i>Đơn hàng đang xử lý (@donChuaXuLy.Count)</h3>
    <div class="card shadow-sm border-0 mb-5">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">Ngày đặt</th>
                            <th class="py-3">Khách hàng</th>
                            <th class="py-3" style="width: 25%;">Tên sản phẩm (SL)</th>
                            <th class="py-3">Size</th>
                            <th class="py-3">Màu sắc</th>
                            <th class="py-3">Tổng tiền</th>
                            <th class="py-3">Trạng thái</th>
                            <th class="pe-4 py-3 text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in donChuaXuLy)
                        {
                            <tr>
                                <td class="ps-4 py-3 text-muted small">@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="py-3">
                                    <a asp-controller="KhachHangs" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none fw-bold" target="_blank" title="Xem hồ sơ">
                                        @(item.KhachHang != null ? item.KhachHang.Hoten : "Khách ẩn danh") <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                    </a>
                                </td>
                                
                                <td class="py-3">
                                    <ul class="list-unstyled mb-0 small">
                                        @foreach (var ct in item.ChiTietThanhToans)
                                        {
                                            <li class="mb-1 text-truncate"><strong>@ct.SoLuong x</strong> @(ct.SanPham?.TenSP ?? "SP đã xóa")</li>
                                        }
                                    </ul>
                                </td>
                                <td class="py-3">
                                    <ul class="list-unstyled mb-0 small text-center">
                                        @foreach (var ct in item.ChiTietThanhToans)
                                        {
                                            <li class="mb-1 fw-bold">@(ct.KichThuoc ?? "-")</li>
                                        }
                                    </ul>
                                </td>
                                <td class="py-3">
                                    <ul class="list-unstyled mb-0 small text-center">
                                        @foreach (var ct in item.ChiTietThanhToans)
                                        {
                                            <li class="mb-1">@(ct.MauSac ?? "-")</li>
                                        }
                                    </ul>
                                </td>

                                <td class="py-3 fw-bold text-danger">@item.TongTien.ToString("N0") đ</td>
                                <td class="py-3"><span class="badge @(item.TrangThai == "Chờ xác nhận" ? "bg-warning text-dark" : "bg-info text-dark") px-2 py-1 fs-6">@item.TrangThai</span></td>
                                <td class="pe-4 py-3 text-center">
                                    <form asp-controller="NhanViens" asp-action="CapNhatTrangThai" method="post" class="d-flex justify-content-center" onsubmit="return xacNhanCapNhat(event, this);">
                                        <input type="hidden" name="maTT" value="@item.MaTT" />
                                        <select name="trangThaiMoi" class="form-select form-select-sm me-2 shadow-sm" style="width: 140px;">
                                            <option value="Chờ xác nhận" selected="@(item.TrangThai == "Chờ xác nhận")">Chờ xác nhận</option>
                                            <option value="Đang giao" selected="@(item.TrangThai == "Đang giao")">Đang giao</option>
                                            <option value="Giao hàng thành công">Giao hàng thành công</option>
                                            <option value="Đã hủy">Đã hủy</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-dark px-3 shadow-sm">Lưu</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!donChuaXuLy.Any())
                        {
                            <tr><td colspan="8" class="text-center py-4 text-muted">Không có đơn hàng nào đang chờ xử lý.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <h4 class="fw-bold mb-3 text-success"><i class="bi bi-check-circle-fill me-2"></i>Đơn hàng Giao thành công (@donThanhCong.Count)</h4>
    <div class="card shadow-sm border-0 mb-5">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-success text-white">
                        <tr>
                            <th class="ps-4 py-3">Ngày đặt</th>
                            <th class="py-3">Khách hàng</th>
                            <th class="py-3" style="width: 25%;">Tên sản phẩm (SL)</th>
                            <th class="py-3">Size</th>
                            <th class="py-3">Màu sắc</th>
                            <th class="py-3">Tổng tiền</th>
                            <th class="pe-4 py-3">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in donThanhCong)
                        {
                            <tr class="table-light">
                                <td class="ps-4 py-3 text-muted small">@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="py-3">
                                    <a asp-controller="KhachHangs" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none fw-bold text-dark" target="_blank">
                                        @(item.KhachHang != null ? item.KhachHang.Hoten : "Khách ẩn danh")
                                    </a>
                                </td>
                                <td class="py-3">
                                    <ul class="list-unstyled mb-0 small text-muted">
                                        @foreach (var ct in item.ChiTietThanhToans)
                                        {
                                            <li class="mb-1 text-truncate"><strong>@ct.SoLuong x</strong> @(ct.SanPham?.TenSP ?? "SP đã xóa")</li>
                                        }
                                    </ul>
                                </td>
                                <td class="py-3"><ul class="list-unstyled mb-0 small text-center text-muted">@foreach (var ct in item.ChiTietThanhToans) {
                                    <li class="mb-1">@(ct.KichThuoc ?? "-")</li>
                                }
                            </ul></td>
                            <td class="py-3"><ul class="list-unstyled mb-0 small text-center text-muted">@foreach (var ct in item.ChiTietThanhToans) {
                                <li class="mb-1">@(ct.MauSac ?? "-")</li>
                            }
                        </ul></td>
                        <td class="py-3 fw-bold text-success">@item.TongTien.ToString("N0") đ</td>
                        <td class="pe-4 py-3"><span class="badge bg-success px-3 py-2"><i class="bi bi-lock-fill me-1"></i>Đã chốt</span></td>
                    </tr>
                }
                @if (!donThanhCong.Any())
                {
                    <tr><td colspan="7" class="text-center py-4 text-muted">Chưa có đơn hàng nào hoàn thành.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
</div>

<h4 class="fw-bold mb-3 text-danger"><i class="bi bi-x-circle-fill me-2"></i>Đơn hàng Đã hủy (@donDaHuy.Count)</h4>
<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-danger text-white">
                    <tr>
                        <th class="ps-4 py-3">Ngày đặt</th>
                        <th class="py-3">Khách hàng</th>
                        <th class="py-3" style="width: 25%;">Tên sản phẩm (SL)</th>
                        <th class="py-3">Size</th>
                        <th class="py-3">Màu sắc</th>
                        <th class="py-3">Tổng tiền</th>
                        <th class="pe-4 py-3">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in donDaHuy)
                    {
                        <tr class="table-light opacity-75">
                            <td class="ps-4 py-3 text-muted small">@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="py-3">
                                <a asp-controller="KhachHangs" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none fw-bold text-secondary" target="_blank">
                                    @(item.KhachHang != null ? item.KhachHang.Hoten : "Khách ẩn danh")
                                </a>
                            </td>
                            <td class="py-3 text-decoration-line-through">
                                <ul class="list-unstyled mb-0 small text-muted">
                                    @foreach (var ct in item.ChiTietThanhToans)
                                    {
                                        <li class="mb-1 text-truncate"><strong>@ct.SoLuong x</strong> @(ct.SanPham?.TenSP ?? "SP đã xóa")</li>
                                    }
                                </ul>
                            </td>
                            <td class="py-3"><ul class="list-unstyled mb-0 small text-center text-muted">@foreach (var ct in item.ChiTietThanhToans) {
                                <li class="mb-1">@(ct.KichThuoc ?? "-")</li>
                            }
                        </ul></td>
                        <td class="py-3"><ul class="list-unstyled mb-0 small text-center text-muted">@foreach (var ct in item.ChiTietThanhToans) {
                            <li class="mb-1">@(ct.MauSac ?? "-")</li>
                        }
                    </ul></td>
                    <td class="py-3 fw-bold text-secondary text-decoration-line-through">@item.TongTien.ToString("N0") đ</td>
                    <td class="pe-4 py-3"><span class="badge bg-secondary px-3 py-2"><i class="bi bi-lock-fill me-1"></i>Đã hủy</span></td>
                </tr>
            }
            @if (!donDaHuy.Any())
            {
                <tr><td colspan="7" class="text-center py-4 text-muted">Không có đơn hàng nào bị hủy.</td></tr>
            }
        </tbody>
    </table>
</div>
</div>
</div>
</div>

@section Scripts {
    <script>
        function xacNhanCapNhat(e, form) {
            e.preventDefault();
            var select = form.querySelector('select[name="trangThaiMoi"]');
            var trangThaiMoi = select.options[select.selectedIndex].text;

            Swal.fire({
                title: 'Xác nhận thay đổi?',
                text: "Bạn có chắc chắn muốn chuyển đơn hàng này sang trạng thái: " + trangThaiMoi + "?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#212529',
                cancelButtonColor: '#dc3545',
                confirmButtonText: 'Đồng ý',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            })
        }
    </script>
}