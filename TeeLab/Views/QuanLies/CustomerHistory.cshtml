@{
    var kh = ViewBag.KhachHang as TeeLab.Models.KhachHang;
    ViewData["Title"] = "Lịch sử mua hàng";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">LỊCH SỬ MUA HÀNG: @kh.Hoten.ToUpper()</h5>
            <span class="badge bg-primary">SĐT: @kh.Sdt</span>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Ngày Đặt</th>
                        <th>Mã Đơn</th>
                        <th>Tổng Tiền</th>
                        <th>Trạng Thái</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var don in Model)
                    {
                        <tr>
                            <td>@don.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>#@don.Id</td>
                            <td class="fw-bold text-success">@don.TongTien.ToString("N0") VNĐ</td>
                            <td>
                                <span class="badge @(don.TrangThai == "Giao hàng thành công" ? "bg-success" : "bg-secondary")">
                                    @don.TrangThai
                                </span>
                            </td>
                            <td>
                                @* Chỗ này trỏ về trang chi tiết đơn hàng của ông *@
                                <a asp-controller="QuanLies"
                                       asp-action="OrderDetails"
                                       asp-route-id="@don.MaTT"
                                       class="btn btn-sm btn-outline-primary">
                                    Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <a asp-action="ManegerCustomers" class="btn btn-secondary mt-3">Quay lại</a>
        </div>
    </div>
</div>