@model Teelab.Models.SanPham

@{
    ViewData["Title"] = "Thêm mới sản phẩm";
}

<h2 class="mt-3 mb-4">Thêm mới sản phẩm</h2>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Create" enctype="multipart/form-data" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="MaSP" class="fw-bold mb-1">Mã sản phẩm</label>
                        <input asp-for="MaSP" class="form-control" placeholder="VD: AT003" />
                        <span asp-validation-for="MaSP" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="TenSP" class="fw-bold mb-1">Tên sản phẩm</label>
                        <input asp-for="TenSP" class="form-control" />
                        <span asp-validation-for="TenSP" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="SoTien" class="fw-bold mb-1">Giá bán (VNĐ)</label>
                        <input asp-for="SoTien" class="form-control" type="number" />
                        <span asp-validation-for="SoTien" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="SoLuong" class="fw-bold mb-1">Số lượng nhập kho</label>
                        <input asp-for="SoLuong" class="form-control" type="number" min="0" />
                        <span asp-validation-for="SoLuong" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label class="fw-bold mb-2">Kích thước (Size)</label>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var size in new[] { "S", "M", "L", "XL", "XXL" })
                            {
                                <div class="form-check">
                                    <input class="form-check-input border-dark" type="checkbox" name="selectedSizes" value="@size" id="size_@size">
                                    <label class="form-check-label user-select-none" for="size_@size" style="cursor: pointer;">@size</label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="fw-bold mb-2">Màu sắc</label>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var color in new[] { "Đen", "Trắng", "Xám", "Kem", "Đỏ", "Xanh Navy", "Hồng" })
                            {
                                <div class="form-check">
                                    <input class="form-check-input border-dark" type="checkbox" name="selectedColors" value="@color" id="color_@color">
                                    <label class="form-check-label user-select-none" for="color_@color" style="cursor: pointer;">@color</label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="fw-bold mb-1">Hình ảnh sản phẩm</label>
                        <input type="file" name="hinhAnhSP" class="form-control" accept="image/*" />
                    </div>
                </div>
                
                <div class="col-12">
                    <div class="form-group mb-4">
                        <label asp-for="MoTa" class="fw-bold mb-1">Mô tả sản phẩm</label>
                        <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="MoTa" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mt-2">
                <button type="submit" class="btn btn-primary px-4 me-2">Lưu sản phẩm</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy & Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}