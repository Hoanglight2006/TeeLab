@model Teelab.Models.SanPham

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<h2 class="mt-3 mb-4 text-danger">Xóa sản phẩm</h2>

<div class="alert alert-warning shadow-sm border-0" role="alert">
    <h4 class="alert-heading"><i class="bi bi-exclamation-triangle-fill"></i> Cảnh báo!</h4>
    <p>Bạn có chắc chắn muốn xóa sản phẩm <strong>@Model.TenSP</strong> không? Hành động này không thể hoàn tác.</p>
</div>

<div class="card shadow-sm border-0 mt-3">
    <div class="card-body p-4">
        <div class="row align-items-center">
            <div class="col-md-2 text-center">
                @if (!string.IsNullOrEmpty(Model.HinhAnh))
                {
                    <img src="~/images/sanpham/@Model.HinhAnh" class="img-thumbnail" style="max-height: 100px;" />
                }
            </div>
            <div class="col-md-10">
                <h4 class="fw-bold">@Model.TenSP (@Model.MaSP)</h4>
                <p class="mb-1"><strong>Giá:</strong> <span class="text-danger">@Model.SoTien.ToString("N0") VNĐ</span></p>
                <p class="mb-1"><strong>Trong kho:</strong> @Model.SoLuong cái</p>
            </div>
        </div>

        <hr />
        
        <form asp-action="Delete" method="post" class="mt-3">
            <input type="hidden" asp-for="MaSP" />
            <button type="submit" class="btn btn-danger px-4 me-2">Xác nhận Xóa</button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
        </form>
    </div>
</div>