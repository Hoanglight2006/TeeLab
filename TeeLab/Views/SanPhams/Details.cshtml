@model Teelab.Models.SanPham

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<h2 class="mt-3 mb-4">Chi tiết: <span class="text-info">@Model.TenSP</span></h2>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <div class="row">
            <div class="col-md-4 text-center mb-3">
                @if (!string.IsNullOrEmpty(Model.HinhAnh))
                {
                    <img src="~/images/sanpham/@Model.HinhAnh" class="img-fluid rounded shadow-sm border" style="max-height: 350px;" />
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center text-muted rounded shadow-sm" style="height: 350px;">
                        Chưa có hình ảnh
                    </div>
                }
            </div>
            
            <div class="col-md-8">
                <table class="table table-borderless">
                    <tbody>
                        <tr>
                            <th style="width: 150px;">Mã sản phẩm:</th>
                            <td>@Model.MaSP</td>
                        </tr>
                        <tr>
                            <th>Giá bán:</th>
                            <td class="text-danger fw-bold fs-5">@Model.SoTien.ToString("N0") VNĐ</td>
                        </tr>
                        <tr>
                            <th>Tồn kho:</th>
                            <td>@Model.SoLuong cái</td>
                        </tr>
                        <tr>
                            <th>Tình trạng:</th>
                            <td>
                                <span class="badge @(Model.TinhTrang == "Còn hàng" ? "bg-success" : "bg-danger") fs-6">
                                    @Model.TinhTrang
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th>Kích thước:</th>
                            <td>@(string.IsNullOrEmpty(Model.KichThuoc) ? "Không có" : Model.KichThuoc)</td>
                        </tr>
                        <tr>
                            <th>Màu sắc:</th>
                            <td>@(string.IsNullOrEmpty(Model.MauSac) ? "Không có" : Model.MauSac)</td>
                        </tr>
                        <tr>
                            <th>Mô tả:</th>
                            <td class="text-muted">@(string.IsNullOrEmpty(Model.MoTa) ? "Chưa có mô tả" : Model.MoTa)</td>
                        </tr>
                    </tbody>
                </table>

                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model?.MaSP" class="btn btn-primary px-4 me-2">Chỉnh sửa</a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Quay lại danh sách</a>
                </div>
            </div>
        </div>
    </div>
</div>