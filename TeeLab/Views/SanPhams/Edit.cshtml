@model Teelab.Models.SanPham

@{
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<h2 class="mt-3 mb-4">Cập nhật sản phẩm: <span class="text-primary">@Model.TenSP</span></h2>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="MaSP" />
            
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="TenSP" class="fw-bold mb-1">Tên sản phẩm</label>
                        <input asp-for="TenSP" class="form-control" />
                        <span asp-validation-for="TenSP" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="SoTien" class="fw-bold mb-1">Giá bán (VNĐ)</label>
                        <input asp-for="SoTien" class="form-control" type="text" value="@Model?.SoTien.ToString("0")" />
                        <span asp-validation-for="SoTien" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TenSP" class="fw-bold mb-1">Tên sản phẩm</label>
                            <input asp-for="TenSP" class="form-control" />
                            <span asp-validation-for="TenSP" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="SoTien" class="fw-bold mb-1">Giá bán (VNĐ)</label>
                            <input asp-for="SoTien" class="form-control" type="text" value="@Model?.SoTien.ToString("0")" />
                            <span asp-validation-for="SoTien" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="SoLuong" class="fw-bold mb-1">Số lượng trong kho</label>
                            <input asp-for="SoLuong" class="form-control" type="number" min="0" />
                            <span asp-validation-for="SoLuong" class="text-danger"></span>
                        </div>

                        @{
                            // Lấy data cũ, tách thành mảng để so sánh
                            var currentSizes = string.IsNullOrEmpty(Model.KichThuoc) ? new string[0] : Model.KichThuoc.Split(new[] { ',', ' ' }, StringSplitOptions.RemoveEmptyEntries);
                            var currentColors = string.IsNullOrEmpty(Model.MauSac) ? new string[0] : Model.MauSac.Split(new[] { ',', ' ' }, StringSplitOptions.RemoveEmptyEntries);
                        }

                        <div class="form-group mb-4 mt-4">
                            <label class="fw-bold mb-2">Kích thước (Size)</label>
                            <div class="d-flex flex-wrap gap-3">
                                @foreach (var size in new[] { "S", "M", "L", "XL", "XXL" })
                                {
                                    bool isChecked = currentSizes.Contains(size);
                                    <div class="form-check">
                                        <input class="form-check-input border-dark" type="checkbox" name="selectedSizes" value="@size" id="size_@size" @(isChecked ? "checked" : "")>
                                        <label class="form-check-label user-select-none" for="size_@size" style="cursor: pointer;">@size</label>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label class="fw-bold mb-2">Màu sắc</label>
                            <div class="d-flex flex-wrap gap-3">
                                @foreach (var color in new[] { "Đen", "Trắng", "Xám", "Kem", "Đỏ", "Xanh Navy", "Hồng" })
                                {
                                    bool isChecked = currentColors.Contains(color);
                                    <div class="form-check">
                                        <input class="form-check-input border-dark" type="checkbox" name="selectedColors" value="@color" id="color_@color" @(isChecked ? "checked" : "")>
                                        <label class="form-check-label user-select-none" for="color_@color" style="cursor: pointer;">@color</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label class="fw-bold mb-1 d-block">Hình ảnh hiện tại</label>
                        @if (!string.IsNullOrEmpty(Model.HinhAnh))
                        {
                            <img src="~/images/sanpham/@Model.HinhAnh" class="img-thumbnail mb-2" style="max-height: 150px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="text-muted fst-italic mb-2">Chưa có ảnh</div>
                        }
                        <label class="fw-bold mb-1">Thay đổi ảnh (Bỏ trống nếu giữ nguyên)</label>
                        <input type="file" name="hinhAnhSP" class="form-control" accept="image/*" />
                    </div>
                </div>

                <div class="col-12">
                    <div class="form-group mb-4">
                        <label asp-for="MoTa" class="fw-bold mb-1">Mô tả sản phẩm</label>
                        <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>

            <div class="form-group mt-2">
                <button type="submit" class="btn btn-primary px-4 me-2">Lưu thay đổi</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}