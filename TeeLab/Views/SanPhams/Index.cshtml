@model IEnumerable<Teelab.Models.SanPham>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<h1 class="mt-3">Danh sách sản phẩm</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Tạo mới sản phẩm</a>
</p>
<table class="table table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Ảnh</th>
            <th>Mã SP</th>
            <th>Tên sản phẩm</th>
            <th>Giá tiền</th>
            <th>Kho</th>
            <th>Size</th>
            <th>Màu</th>
            <th>Tình trạng</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                    {
                        <img src="~/images/sanpham/@item.HinhAnh" width="50" height="50" style="object-fit: cover;" />
                    }
                </td>
                <td>@item.MaSP</td>
                <td class="fw-bold">@item.TenSP</td>
                <td>@item.SoTien.ToString("N0")</td>
                <td>@item.SoLuong</td>
                <td><small>@item.KichThuoc</small></td>
                <td><small>@item.MauSac</small></td>
                <td>
                    <span class="badge @(item.TinhTrang == "Còn hàng" ? "bg-success" : "bg-danger")">
                        @item.TinhTrang
                    </span>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.MaSP" class="btn btn-sm btn-outline-primary">Sửa</a>
                    <a asp-action="Details" asp-route-id="@item.MaSP" class="btn btn-sm btn-outline-info">Chi tiết</a>
                    <a asp-action="Delete" asp-route-id="@item.MaSP" class="btn btn-sm btn-outline-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>