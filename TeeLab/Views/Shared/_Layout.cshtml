@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using Teelab.Models
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Teelab</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* Icon giỏ hàng, mạng xã hội và các icon tiện ích *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Teelab.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">Teelab</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        
                        @if (User.Identity.IsAuthenticated && (User.IsInRole("QuanLy") || User.IsInRole("NhanVien")))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-controller="SanPhams" asp-action="Index">Quản lý sản phẩm</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @* Giỏ hàng giữ nguyên logic cũ *@
                        <li class="nav-item me-3">
                            <a class="nav-link text-dark position-relative" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart4 fs-5"></i>
                                @{
                                    var sessionData = Context.Session.GetString("GioHang");
                                    var cart = sessionData == null ? new List<CartItem>() : JsonSerializer.Deserialize<List<CartItem>>(sessionData);
                                    var count = cart?.Sum(x => x.SoLuong) ?? 0;
                                }
                                @if (count > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
                                        @count
                                    </span>
                                }
                            </a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @* Thay đổi phần hiển thị tên thành Dropdown để chứa Trang cá nhân *@
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Chào, <strong>@User.Identity.Name</strong>!
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="bi bi-person-circle me-2"></i>Trang cá nhân
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="form-inline">
                                            <button type="submit" class="dropdown-item text-danger border-0 bg-transparent w-100 text-start" style="cursor:pointer;">
                                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* Footer tràn viền mới *@
    <footer class="footer-section">
        <div class="footer-container text-center">
            <div class="footer-logo">Teelab</div>

            <ul class="footer-menu">
                <li><a asp-controller="Home" asp-action="Index">HOME</a></li>
                <li><a href="#">PRODUCT</a></li>
                <li><a href="#">ABOUT</a></li>
                <li><a href="#">BLOG</a></li>
                <li><a href="#">CONTACT</a></li>
            </ul>

            <div class="footer-social">
                <a href="#" class="icon-circle"><i class="fab fa-twitter"></i></a>
                <a href="#" class="icon-circle"><i class="fab fa-facebook-f"></i></a>
                <a href="#" class="icon-circle"><i class="fab fa-instagram"></i></a>
            </div>

            <div class="copyright">
                <p>Copyright &copy; @DateTime.Now.Year All rights reserved | Website bán áo thun <a asp-controller="Home" asp-action="Index">Teelab</a></p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>