@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using Teelab.Models
@{
    // Lấy tên Controller và Action để kiểm tra xem có phải trang Login không
    var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
    var action = ViewContext.RouteData.Values["Action"]?.ToString();
    bool isLoginPage = (controller == "Account" && action == "Login");
}
<!DOCTYPE html>
<html lang="en">
<head>
    
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TeeLab</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TeeLab.styles.css" asp-append-version="true" />
<style>
    /* Nút mở chat: Tông xám hiện đại, đổ bóng mềm */
    #btn-chat-open {
        position: fixed; bottom: 30px; right: 30px;
        width: 60px; height: 60px; z-index: 9999;
        background: #495057 !important;
        border: none !important;
        border-radius: 18px !important;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        display: flex; align-items: center; justify-content: center;
        transition: all 0.3s ease;
    }
    #btn-chat-open:hover { transform: translateY(-3px); background: #343a40 !important; }
    #btn-chat-open i { font-size: 24px; color: #fff; }

    /* Khung chat */
    #chat-window {
        position: fixed; bottom: 105px; right: 30px;
        width: 370px; height: 580px; z-index: 9999;
        display: none; flex-direction: column;
        background: #fff; border-radius: 24px;
        border: 1px solid rgba(0,0,0,0.05) !important;
        box-shadow: 0 15px 40px rgba(0,0,0,0.12);
        overflow: hidden;
    }

    /* FIX: Header với chữ màu đen đậm trên nền xám nhạt cực sang */
    #chat-window .card-header {
        background: #f8f9fa !important; /* Nền xám nhạt */
        color: #212529 !important;    /* Chữ đen đậm để nổi bật */
        padding: 18px 22px; 
        border-bottom: 1px solid #eee;
        display: flex; justify-content: space-between; align-items: center;
    }
    
    /* Căn chỉnh chữ TeeLab đẹp hơn */
    #chat-window .card-header span { 
        font-weight: 800; 
        font-size: 16px; 
        letter-spacing: -0.5px;
        display: flex; align-items: center; gap: 8px; 
    }
    
    /* Chấm xanh trạng thái tinh tế */
    #chat-window .card-header span::before {
        content: ""; width: 8px; height: 8px; 
        background: #27ae60; border-radius: 50%;
    }

    #chat-body {
        flex: 1; overflow-y: auto; padding: 20px;
        background-color: #ffffff;
        display: flex; flex-direction: column; gap: 14px;
    }

    /* Cải thiện ô chat của khách (User Message) */
    .user-msg {
        align-self: flex-end;
        background: #343a40; /* Màu xám than chì hiện đại */
        color: #fff;
        padding: 12px 16px;
        font-size: 14px;
        border-radius: 20px 20px 4px 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        max-width: 80%;
    }

    /* Tin nhắn của Bot */
    .bot-msg {
        align-self: flex-start;
        background: #f1f3f5;
        color: #333;
        padding: 12px 16px;
        font-size: 14px;
        border-radius: 20px 20px 20px 4px;
        max-width: 85%;
        border: 1px solid #e9ecef;
    }

    /* Footer và Input căn chỉnh lại cho hiện đại */
    #chat-window .card-footer {
        background: #fff; border-top: 1px solid #f1f1f1; padding: 15px 20px;
    }
    
    .input-group {
        background: #f8f9fa; 
        border-radius: 15px;
        padding: 8px 15px; 
        border: 1px solid #dee2e6;
        display: flex; align-items: center;
        transition: 0.3s ease;
    }
    
    .input-group:focus-within {
        border-color: #adb5bd;
        box-shadow: 0 0 0 3px rgba(0,0,0,0.05);
        background: #fff;
    }

    #chat-input {
        border: none !important; background: transparent !important;
        box-shadow: none !important; font-size: 14px; flex: 1;
        outline: none; color: #333;
    }

    #btn-send {
        background: transparent !important; 
        color: #495057 !important;
        border: none; font-weight: 700;
        cursor: pointer; padding-left: 10px;
    }
    #btn-send:hover { color: #000 !important; }

    /* Thanh cuộn mảnh */
    #chat-body::-webkit-scrollbar { width: 4px; }
    #chat-body::-webkit-scrollbar-thumb { background: #e9ecef; border-radius: 10px; }
</style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">TeeLab</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        
                        @if (!User.IsInRole("QuanLy") && !User.IsInRole("NhanVien"))
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link text-dark position-relative" asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-cart4 fs-5"></i>
                                    @{
                                        // Giữ nguyên logic giỏ hàng của bạn
                                        var sessionData = Context.Session.GetString("GioHang");
                                        var cart = sessionData == null ? new List<CartItem>() : JsonSerializer.Deserialize<List<CartItem>>(sessionData);
                                        var count = cart?.Sum(x => x.SoLuong) ?? 0;
                                    }
                                    @if (count > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
                                            @count
                                        </span>
                                    }
                                </a>
                            </li>
                        }

                        @if (User.Identity.IsAuthenticated)
                        {
                            // Lấy Avatar: Ưu tiên Session, nếu không có thì dùng ảnh mặc định
                            var userAvatar = Context.Session.GetString("UserAvatar") ?? "/images/avatars/default-avatar.png";
                            <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark d-flex align-items-center" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            
            @* --- ĐÂY LÀ THẺ IMG HIỂN THỊ AVATAR --- *@
                                    <img src="@userAvatar"
                 class="rounded-circle me-2" 
                 style="width: 35px; height: 35px; object-fit: cover; border: 1px solid #ececec;" 
                 onerror="this.src='/images/avatars/default-avatar.png';" />
            
            Chào, <strong>@User.Identity.Name</strong>!
        </a>
        <ul class="dropdown-menu dropdown-menu-end">
                                    @if (User.IsInRole("QuanLy"))
                                    {
                                        <li>
                                            <a class="dropdown-item fw-bold text-primary" asp-controller="QuanLies" asp-action="Index">
                                                <i class="bi bi-speedometer2 me-2"></i>Quản lí
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    @if (User.IsInRole("NhanVien"))
                                    {
                                        <li>
                                            <a class="dropdown-item fw-bold text-primary" asp-controller="NhanViens" asp-action="Index">
                                                <i class="bi bi-speedometer2 me-2"></i>Quản lí đơn hàng
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    @if (User.IsInRole("KhachHang"))
                                    {
                                        <li>
                                            <a class="dropdown-item fw-bold text-primary" asp-controller="KhachHangs" asp-action="Index">
                                                <i class="bi bi-speedometer2 me-2"></i>Đơn hàng của bạn
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
            <li>
                <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                    <i class="bi bi-person-circle me-2"></i>Trang cá nhân
                </a>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="dropdown-item text-danger border-0 bg-transparent w-100 text-start">
                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                    </button>
                </form>
            </li>
        </ul>
    </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
        @if (!isLoginPage)
        {
            @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Home" &&
                                             ViewContext.RouteData.Values["action"]?.ToString() == "Index")
            {
                <footer class="footer-section pt-5 pb-3">
                    <div class="container">
                        <div class="row">
                            <div class="col-md-2 mb-4">
                                <h6 class="fw-bold text-u   ppercase mb-3">FAQ</h6>
                                <ul class="list-unstyled">
                                    <li><a href="#" class="text-decoration-none text-dark">Track Your Order</a></li>
                                </ul>
                            </div>

                            <div class="col-md-4 mb-4">
                                <h6 class="fw-bold text-uppercase mb-3">Client Services</h6>
                                <ul class="list-unstyled footer-link-list">
                                    <li><a href="#">Chính sách mua hàng</a></li>
                                    <li><a href="#">Chính sách bảo mật thông tin</a></li>
                                    <li><a href="#">Phương thức thanh toán</a></li>
                                    <li><a href="#">Chính sách trả hàng</a></li>
                                    <li><a href="#">Chính sách giao nhận, vận chuyển, kiểm hàng</a></li>
                                </ul>
                            </div>

                            <div class="col-md-6 mb-4">
                                <h6 class="fw-bold text-uppercase mb-3">Newsletter</h6>
                                <p class="small text-uppercase fw-semibold" style="line-height: 1.6;">
                                    Sign up to receive email updates on our latest collections, products, fashion shows, and projects.
                                    I agree to receive Teelab newsletter to be the first to know about new collections, exclusive product launches, events, and avalane services.
                                    By subscribing, I accept Teelab privacy policy.
                                </p>
                                <div class="newsletter-form d-flex mt-3">
                                    <input type="email" class="form-control rounded-pill-start border-end-0" placeholder="Email address">
                                    <button class="btn btn-dark rounded-pill-end px-4 text-uppercase fw-bold" type="button">Send</button>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="row mt-4 align-items-start">
                            <div class="col-md-4 mb-4">
                                <div class="d-flex gap-3">
                                    <a href="#" class="text-dark fs-4"><i class="bi bi-facebook"></i></a>
                                    <a href="#" class="text-dark fs-4"><i class="bi bi-instagram"></i></a>
                                    <a href="#" class="text-dark fs-4"><i class="bi bi-tiktok"></i></a>
                                    <a href="#" class="text-dark fs-4"><i class="bi bi-threads"></i></a>
                                    <a href="#" class="text-dark fs-4"><i class="bi bi-youtube"></i></a>
                                </div>
                            </div>

                            <div class="col-md-8 d-flex justify-content-md-end">

                                <div class="footer-business-info text-start" style="max-width: 600px;">
                                    <h6 class="fw-bold mb-2">HKD thời trang Huệ Nguyễn</h6>
                                    <p class="small mb-1">Giấy chứng nhận đăng ký hộ kinh doanh số 019171001898 do Phòng Kinh tế, hạ tầng và đô thị - UBND Phường Nghĩa Đô cấp ngày 23/01/2026</p>
                                    <p class="small mb-1">Địa chỉ: Số 34 Ngõ 225 Quan Hoa, Phường Nghĩa Đô, Thành phố Hà Nội, Việt Nam</p>
                                    <p class="small mb-1">Email: teelabvn@gmail.com</p>
                                    <p class="small mb-2">Điện thoại: 0865539083</p>


                                </div>

                            </div>
                        </div>

                        <div class="mt-4 text-center text-md-start">
                            <span class="fw-bold" style="font-size: 14px;">teelab:alter</span>
                        </div>

                </footer>
            }
        }
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    @if (TempData["CheckoutSuccess"] != null)
    {
        <script>
            Swal.fire({
            title: 'Thành công!',
            text: '@Html.Raw(TempData["CheckoutSuccess"])',
            icon: 'success',
            confirmButtonColor: '#212529',
            confirmButtonText: 'Ok',
            allowOutsideClick: false
            }).then((result) => {
            if (result.isConfirmed) {
            window.location.href = '/KhachHangs';
            }
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
<button id="btn-chat-open" class="btn btn-dark rounded-circle shadow" style="position:fixed; bottom:20px; right:20px; width:60px; height:60px; z-index:9999;">
    <i class="bi bi-chat-dots-fill" style="font-size: 24px; color: white;"></i>
</button>

<div id="chat-window" class="card shadow" style="display:none; position:fixed; bottom:90px; right:20px; width:350px; height:500px; z-index:9999; border-radius: 15px; overflow: hidden;">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <span class="fw-bold">Trợ lý ảo TeeLab</span>
        <button class="btn btn-sm text-white border-0" onclick="$('#chat-window').fadeOut(200)">X</button>
    </div>
    
    <div id="chat-body" class="card-body" style="overflow-y:auto; background-color: #f8f9fa; display: flex; flex-direction: column; gap: 10px; padding: 15px;">
        </div>
    
    <div class="card-footer bg-white border-top-0">
        <div class="input-group">
            <input type="text" id="chat-input" class="form-control rounded-pill-start" placeholder="Hỏi TeeLab ngay..." style="font-size: 14px;">
            <button id="btn-send" class="btn btn-dark rounded-pill-end">Gửi</button>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<script>
$(document).ready(function() {
    // 1. Fix lỗi nhấn không hiện bằng cách dùng fadeToggle
    $('#btn-chat-open').off('click').on('click', function() {
        $('#chat-window').fadeToggle(200, function() {
            if($(this).is(':visible')) {
                $(this).css('display', 'flex'); // Ép kiểu flex để body không bị vỡ
            }
        });
    });

    // 2. Xử lý gửi tin nhắn
    function sendMessage() {
        const input = $('#chat-input');
        const msg = input.val().trim();
        if (!msg) return;

        // Thêm tin nhắn User
        $('#chat-body').append(`<div class="msg-item user-msg" style="align-self: flex-end; background: #000; color: #fff; padding: 8px 12px; border-radius: 15px 15px 2px 15px; max-width: 85%; margin-bottom: 5px;">${msg}</div>`);
        input.val('');
        
        // Cuộn xuống cuối
        $('#chat-body').scrollTop($('#chat-body')[0].scrollHeight);

        // Hiệu ứng đang trả lời
        const typingId = "typing-" + Date.now();
        $('#chat-body').append(`<div id="${typingId}" class="msg-item bot-msg" style="align-self: flex-start; background: #eee; padding: 8px 12px; border-radius: 15px 15px 15px 2px; font-style: italic; color: #666;">TeeLab đang trả lời...</div>`);

        $.ajax({
            url: '/Assistant/Ask',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ message: msg }),
            success: function(res) {
                $(`#${typingId}`).remove(); 
                
                // Parse Markdown cực chuẩn
                const htmlContent = marked.parse(res.reply.trim()); 

                $('#chat-body').append(`
                    <div class="msg-item bot-msg" style="align-self: flex-start; background: #fff; border: 1px solid #ddd; padding: 10px; border-radius: 15px 15px 15px 2px; max-width: 90%; font-size: 14px; line-height: 1.5;">
                        <div class="bot-content">${htmlContent}</div>
                    </div>
                `);

                $('#chat-body').animate({ scrollTop: $('#chat-body')[0].scrollHeight }, 300);
            },
            error: function() {
                $(`#${typingId}`).html("<span style='color:red;'>Lỗi kết nối, vui lòng thử lại.</span>");
            }
        });
    }

    // 3. Gán sự kiện cho nút Gửi và Enter
    $('#btn-send').click(sendMessage);
    $('#chat-input').on('keypress', function(e) {
        if (e.which == 13) sendMessage();
    });
});
</script>
</body>
</html>