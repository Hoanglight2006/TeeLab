@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using Teelab.Models

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TeeLab</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TeeLab.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">TeeLab</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        
                        @if (!User.IsInRole("QuanLy") && !User.IsInRole("NhanVien"))
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link text-dark position-relative" asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-cart4 fs-5"></i>
                                    @{
                                        var sessionData = Context.Session.GetString("GioHang");
                                        var cart = sessionData == null ? new List<CartItem>() : JsonSerializer.Deserialize<List<CartItem>>(sessionData);
                                        var count = cart?.Sum(x => x.SoLuong) ?? 0;
                                    }
                                    @if (count > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
                                            @count
                                        </span>
                                    }
                                </a>
                            </li>
                        }

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                @if (User.IsInRole("QuanLy"))
                                {
                                    <a class="nav-link text-primary fw-bold" asp-controller="QuanLies" asp-action="Index">
                                        <i class="bi bi-person-circle"></i> Chào, @User.Identity.Name (Admin)
                                    </a>
                                }
                                else if (User.IsInRole("NhanVien"))
                                {
                                    <a class="nav-link text-success fw-bold" asp-controller="NhanViens" asp-action="Index">
                                        <i class="bi bi-person-badge"></i> Chào, @User.Identity.Name
                                    </a>
                                }
                                else
                                {
                                    <a class="nav-link text-dark fw-bold" asp-controller="KhachHangs" asp-action="Index">
                                        <i class="bi bi-person"></i> Chào, @User.Identity.Name
                                    </a>
                                }
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="form-inline">
                                    <button type="submit" class="nav-link btn btn-link text-danger border-0" style="cursor:pointer;">Đăng xuất</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted text-center">
        <div class="container">
            &copy; 2026 - TeeLab - Website bán áo thun
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    @if (TempData["CheckoutSuccess"] != null)
    {
        <script>
            Swal.fire({
            title: 'Thành công!',
            text: '@Html.Raw(TempData["CheckoutSuccess"])',
            icon: 'success',
            confirmButtonColor: '#212529',
            confirmButtonText: 'Ok',
            allowOutsideClick: false /* Không cho click ra ngoài tắt popup */
            }).then((result) => {
            if (result.isConfirmed) {
            // Sau khi bấm nút Tuyệt vời thì mới bay sang Lịch sử đơn hàng
            window.location.href = '/KhachHangs';
            }
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>